# ============================================
# Variables de Entorno - Sistema Transferencias
# ============================================
# Copia este archivo como .env y configura tus valores

# Clave secreta para sesiones (genera una segura)
# Puedes generar una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu-clave-secreta-muy-segura-aqui

# Base de datos
# Para SQLite local:
DATABASE_URL=sqlite:///db/sistema_transferencias.db

# Para MySQL en PythonAnywhere:
# DATABASE_URL=mysql+pymysql://usuario:contraseña@host/base_de_datos

# Configuración de uploads
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216

# Límites de transferencia
LIMITE_TRANSFERENCIA_SEMANAL=999
DIAS_REESTABLECIMIENTO=7

# Entorno (development, production)
FLASK_ENV=development
