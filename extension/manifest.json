{
  "manifest_version": 3,
  "name": "Registro Rápido - Transferencias",
  "version": "1.1",
  "description": "Envía recibos de WU, MG, Ria, Mondial y Monty directo al sistema de control.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Enviar recibo al sistema"
  },
  "icons": {
    "48": "icon.png"
  }
}
